# Copie ce fichier en ".env" et remplis les valeurs réelles
# Ne jamais commiter le fichier .env avec de vraies clés

# URL de l'API FastAPI
# En local : http://localhost:8000
# Sur Railway : https://ton-api.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000
API_URL=http://localhost:8000

# Next-Auth
# En local : http://localhost:3000
# En production : https://ton-app.railway.app
NEXTAUTH_URL=http://localhost:3000

# Générer un secret fort : openssl rand -base64 32
NEXTAUTH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL
